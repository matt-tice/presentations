% ==========================================
% 1. CORE GRAPHICS & STRUCTURAL LAYOUT
% ==========================================
\RequirePackage{graphicx}
\RequirePackage{adjustbox}
\RequirePackage{mdframed}
\RequirePackage{fontawesome5} % Required for \faAsterisk, \faCube, \faLocationArrow

% --- TikZ & Visuals ---
\RequirePackage{tikz}
\RequirePackage{tikz-cd}
\RequirePackage[many]{tcolorbox}
\tcbuselibrary{theorems}

\RequirePackage{tabularx}
% ==========================================
% 2. MATH
% ==========================================
\RequirePackage{amsmath}
\RequirePackage{mathtools}
\RequirePackage{amsthm}
\RequirePackage{amssymb}
\RequirePackage{xparse}

% ==========================================
% 3. MACROS
% ==========================================

% --- Field Theory ---
\newcommand{\exten}[2]{{#2}_{#1}}

% --- Category Theory & Homotopy ---
\newcommand{\colim}{\operatorname{colim}}
\newcommand{\coker}{\operatorname{coker}}
\newcommand{\im}{\operatorname{Im}}
\newcommand{\cat}[1]{\mathcal{#1}}
\newcommand{\mor}[2]{\text{Mor}(#1, #2)}

% --- Topological Space Operators ---
\newcommand{\nbh}[1]{\mathcal{N}_{#1}}

% --- Cryptic Math Object Glyphs ---
\newcommand{\const}{\text{\faAsterisk}}
\newcommand{\obj}{\text{\faCube}}
\newcommand{\morph}{\text{\faLocationArrow}}

% --- Layout & Utility Shorthands ---
\newcommand{\tabitem}{~~\llap{\textbullet}~~}
\newcommand{\newthought}[1]{\medskip\noindent\fbox{{#1}}}

% --- Delimiter Scaling Mechanics ---
\newcommand{\abs}[1]{\lvert #1 \rvert} % Using exact amsmath delimiters rather than standard pipes
\newcommand{\norm}[1]{\left\lVert #1 \right\rVert}
\newcommand{\gen}[1]{\left\langle #1 \right\rangle}



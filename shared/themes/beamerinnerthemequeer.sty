% The inner theme determines the title page, itemize, enumerate, theorem, proof, figures, tables, footnotes, biliography. Basically everything




\setbeamertemplate{background}{
  \begin{tikzpicture}
  \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
  \fill[color=white] (0,2) rectangle (\the\paperwidth,\the\paperheight);
  \fill[color=queer-plum] (0,0) rectangle(2.95,1.9);
  \fill[color=queer-lavender] (7.5,8.5) rectangle(12.65,9.5);
  \fill[color=queer-blue] (3.05,0) rectangle(\the\paperwidth,1.9);
  \fill[color=queer-yellow] (0.3,3) rectangle(1.3,9.4);
  \ifnum\thepage>1\relax%
   \fill[white,opacity=1] (0,0) rectangle(\the\paperwidth,\the\paperheight);
   \fi
  \end{tikzpicture}
}


